[
  {
    "name": "bsp",
    "filename_pattern": "fboss-bsp*.tar",
    "remote_dir": "/home/BSP",
    "install_type": "rpm",
    "find_rpm_dir": "fboss-bsp_IceTea_bsp_x86_evt_1.1.0",
    "rpm_filename": "fboss_bsp_kmods-6.11.1-1.1.0-1.x86_64.rpm"
  },
  {
    "name": "unidiag",
    "filename_pattern": "icetea_unidiag*.tar.gz",
    "remote_dir": "/home/Diag",
    "install_type": "script",
    "install_cmds": [
      "cd packages-icetea && bash ./install.sh"
    ],
    "verify_path_exists": "/usr/local/bin/unidiag",
    "pre_install_cmds": [
      "echo 'Preparing to install unidiag...'"
    ],
    "post_install_cmds": [
      "echo 'unidiag installation complete.'"
    ]
  },
  {
    "filename_pattern": "fboss_bins.tar.zst",
    "name": "fboss",
    "remote_dir": "/opt",
    "install_type": "script",
    "install_cmds": [
      "mkdir -p fboss",
      "mv fboss_bins.tar.zst fboss/",
      "cd fboss && tar -xvf fboss_bins.tar.zst && source ./bin/setup_fboss_env"
    ],
    "verify_path_exists": "/opt/fboss/bin/setup_fboss_env",
    "verify_cmds": [
      "ldd /opt/fboss/bin/platform_manager | grep -v 'not found'",
      "ldd /opt/fboss/bin/fan_service | grep -v 'not found'",
      "ldd /opt/fboss/bin/fw_util | grep -v 'not found'",
      "ldd /opt/fboss/bin/sensor_service | grep -v 'not found'",
      "ldd /opt/fboss/bin/weutil | grep -v 'not found'"
    ],
    "post_install_cmds": [
      "echo 'FBOSS environment setup complete. Consider starting the fboss_startup.sh script.'"
    ]
  },
  {
    "name": "meta_os",
    "version": "4.0.4",
    "remote_dir": "/home/OS",
    "install_type": "os_update",
    "install_script": "install_os.sh",
    "kernel_version": "6.11.1",
    "verify_path_exists": "/etc/VERSION"
  }
]